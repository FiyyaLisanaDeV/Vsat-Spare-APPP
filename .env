# =============================================================================
# VSAT SPARE STOCK MANAGEMENT SYSTEM — ENVIRONMENT VARIABLES
# =============================================================================
# File ini HARUS ada di root project agar Docker Compose bisa membaca variable
# Jangan pernah commit file .env ke GitHub (sudah di-track di .gitignore)
# =============================================================================

# --- DATABASE ------------------------------------------------------------------
# Kredensial PostgreSQL untuk development/testing
POSTGRES_USER=vsat_user
POSTGRES_PASSWORD=vsat_secure_password_2024
POSTGRES_DB=vsat_db

# Connection string untuk backend FastAPI
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://vsat_user:vsat_secure_password_2024@postgres:5432/vsat_db

# --- JWT -----------------------------------------------------------------------
# Secret keys untuk signing JWT tokens (minimal 32 karakter)
# Generate baru untuk production: openssl rand -hex 32
SECRET_KEY=9f8e7d6c5b4a3f2e1d0c9b8a7f6e5d4c3b2a1f0e9d8c7b6a5f4e3d2c1b0a9f
REFRESH_SECRET_KEY=a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ----------------------------------------------------------------------
# Frontend origin yang diizinkan akses ke backend
# Pisahkan dengan koma jika lebih dari satu
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- PGADMIN (opsional untuk development) ------------------------------------
# Kredensial untuk akses PgAdmin
PGADMIN_EMAIL=admin@vsat.local
PGADMIN_PASSWORD=pgadmin_password_2024

# --- BACKUP -------------------------------------------------------------------
# Jumlah hari untuk menyimpan backup
BACKUP_RETENTION=14

# Ukuran maksimal file upload (dalam MB)
MAX_UPLOAD_SIZE_MB=200

# --- PORTS (ubah jika terjadi port conflict) ------------------------------------
# Port mapping untuk setiap service
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5432
PGADMIN_PORT=5050

# --- LOGGING -------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Berapa hari log disimpan sebelum dihapus
LOG_RETENTION_DAYS=30

# --- TIMEZONE -----------------------------------------------------------------
# Timezone untuk aplikasi (gunakan format IANA)
# Opsi: Asia/Jakarta, Asia/Bangkok, UTC, etc.
TZ=Asia/Jakarta

# =============================================================================
# NOTES UNTUK PRODUCTION
# =============================================================================
# 1. GANTI semua password dengan yang kuat dan random
# 2. Generate SECRET_KEY baru: openssl rand -hex 32
# 3. Gunakan environment variables yang dikelola oleh hosting provider
# 4. Jangan hardcode sensitive data di file ini
# 5. Backup file .env di tempat yang aman
# 6. Rotate credentials secara berkala
# =============================================================================
