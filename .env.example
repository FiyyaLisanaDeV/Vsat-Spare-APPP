# =============================================================================
# VSAT SPARE STOCK MANAGEMENT SYSTEM — ENVIRONMENT VARIABLES
# =============================================================================
# PENTING: Salin file ini menjadi .env sebelum menjalankan sistem.
#          Jangan pernah commit file .env ke repository!
# =============================================================================

# --- DATABASE ------------------------------------------------------------------
POSTGRES_USER=vsat_user
POSTGRES_PASSWORD=ganti_password_ini
POSTGRES_DB=vsat_db
DATABASE_URL=postgresql://vsat_user:ganti_password_ini@postgres:5432/vsat_db

# --- JWT -----------------------------------------------------------------------
# Minimal 32 karakter acak. Contoh generate: openssl rand -hex 32
SECRET_KEY=ganti_secret_key_minimal_32_karakter_ini_wajib_diganti
REFRESH_SECRET_KEY=ganti_refresh_secret_key_minimal_32_karakter_ini_wajib_diganti
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ----------------------------------------------------------------------
# Pisahkan dengan koma jika lebih dari satu origin
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- PGADMIN (opsional) -------------------------------------------------------
PGADMIN_EMAIL=admin@vsat.local
PGADMIN_PASSWORD=pgadmin_password

# --- BACKUP -------------------------------------------------------------------
BACKUP_RETENTION=14
MAX_UPLOAD_SIZE_MB=200

# --- PORT (ubah jika terjadi port conflict) ------------------------------------
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5432
PGADMIN_PORT=5050

# --- LOG ----------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# --- TIMEZONE -----------------------------------------------------------------
TZ=Asia/Jakarta
